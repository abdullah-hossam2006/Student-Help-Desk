<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.AdminDashboardController"
      alignment="CENTER"
      spacing="10"
      prefWidth="900"
      prefHeight="650">

    <Label text="Admin Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <TableView fx:id="ticketsTable" prefWidth="850" prefHeight="350">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60" />
            <TableColumn fx:id="studentColumn" text="Student" prefWidth="120" />
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="150" />
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="220" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="120" />
            <TableColumn fx:id="replyColumn" text="Reply" prefWidth="180" />
        </columns>
    </TableView>

    <TextArea fx:id="replyArea" promptText="Write reply here" maxWidth="600" prefHeight="80" />

    <Button text="Reply to Selected Ticket" onAction="#replyToTicket" maxWidth="300" />
    <Button text="Refresh" onAction="#loadTickets" maxWidth="300" />
    <Button text="Logout" onAction="#logout" maxWidth="300" />

    <Label fx:id="messageLabel" textFill="red" />

</VBox>