<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.StudentDashboardController"
      alignment="CENTER"
      spacing="20"
      prefWidth="800"
      prefHeight="600">

    <Label text="Student Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <Button text="Create Ticket" onAction="#goToCreateTicket" maxWidth="300" />
    <Button text="My Tickets" onAction="#goToMyTickets" maxWidth="300" />
    <Button text="Logout" onAction="#logout" maxWidth="300" />

</VBox>