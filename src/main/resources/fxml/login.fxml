<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.LoginController"
      alignment="CENTER"
      spacing="15"
      prefWidth="800"
      prefHeight="600">

    <Label text="Student Help Desk Login" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <TextField fx:id="usernameField" promptText="Username" maxWidth="300" />
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="300" />

    <Button text="Login" onAction="#handleLogin" maxWidth="300" />
    <Button text="Create New Account" onAction="#goToRegister" maxWidth="300" />

    <Label fx:id="messageLabel" textFill="red" />

</VBox>